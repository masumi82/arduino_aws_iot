# AWS IoT Core
IOT_ENDPOINT=xxxxxxxxxxxxxx-ats.iot.ap-northeast-1.amazonaws.com
DEVICE_ID=arduino-mkr-001

# Certificate paths (mounted into container via /etc/arduino_iot/certs)
CERT_PATH=/app/certs/certificate.pem
KEY_PATH=/app/certs/private.key
CA_PATH=/app/certs/root_ca.pem

# UART
UART_PORT=/dev/ttyACM0
UART_BAUDRATE=115200

# Gateway tuning (optional — defaults shown)
# STATUS_DEGRADED_SEC=15
# BUFFER_MAX_SIZE=50
# BUFFER_MAX_AGE_SEC=600
